# =============================================
# JOB HUNTER BOT - Configuração
# =============================================
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# COMO CRIAR O BOT DO TELEGRAM:
# 1. Abra o Telegram e busque @BotFather
# 2. Envie /newbot e siga as instruções
# 3. Copie o token gerado aqui:
TELEGRAM_BOT_TOKEN=

# COMO PEGAR SEU CHAT ID:
# 1. Rode: npm run setup
# 2. Mande qualquer mensagem pro seu bot no Telegram
# 3. O script vai mostrar seu Chat ID, cole aqui:
TELEGRAM_CHAT_ID=

# Intervalo de busca em minutos (padrão: 30)
SEARCH_INTERVAL=30
